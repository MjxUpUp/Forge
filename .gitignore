# Binaries
# /forge 锚定根目录——裸 "forge" 会误伤 cmd/forge/ 源码目录（gitignore 裸名匹配
# 任意路径同名文件/目录），致 cmd/forge 没进仓库、CI build 失败（本地有文件所以本地过）。
/forge
forge.exe
forge-dev.exe
bin/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Build
dist/

# Forge runtime state (entire dir — regenerated by forge init/commands, never tracked)
.forge/
# Hooks are regenerated from internal/hooks/embed.go by autoSync on every
# command — tracking them only causes drift. pipeline.yml/protocol.yml stay
# tracked (user-editable project config, autoSync never overwrites them).
.forge/hooks/
.forge/checklog*.jsonl
.forge/toollog*.jsonl
.forge/session*.json*
.forge/sessions/
.forge/reviews/
.forge/quarantine/
.forge/active-task-ref*
.forge/experience/proposed/
.forge/checkpoints/
.forge/*.last

# Claude Code / ZCode CLI assets (regenerated by skillgen, never tracked)
.claude/
.agents/
AGENTS.md
.openclaw/
.npmrc

# Tool working dirs (not forge source)
.playwright-mcp/

# Local exploration artifacts (not forge source)
dify-forge-*.yml
# Dashboard dev render screenshots (generated by `forge dashboard` during local dev)
dashboard-render.png
