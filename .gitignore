# Binaries
# /forge 锚定根目录——裸 "forge" 会误伤 cmd/forge/ 源码目录（gitignore 裸名匹配
# 任意路径同名文件/目录），致 cmd/forge 没进仓库、CI build 失败（本地有文件所以本地过）。
/forge
forge.exe
forge-dev.exe
bin/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Build
dist/

# Forge project-local config dir: .forge/ houses pipeline.yml / protocol.yml /
# state.json (pipeline state machine) / CLAUDE.md / hooks/ etc. Created by
# `forge init` on demand, never tracked (users run `forge init` again after
# cloning). Runtime state lives in the user-level DataDir
# (~/.forge/projects/<key>/) — see refactor-data-home §1.1. The full-dir ignore
# supersedes any per-subdir rules: hooks/checklog/sessions/etc. inside .forge/
# are all covered; explicit per-name patterns below this block were dropped
# after they shadowed nothing (nothing in .forge/ is tracked, and runtime
# state already moved to DataDir).
.forge/

# Claude Code / ZCode CLI assets (regenerated by skillgen, never tracked)
.claude/
.agents/
AGENTS.md
.openclaw/
.npmrc

# Tool working dirs (not forge source)
.playwright-mcp/

# Local exploration artifacts (not forge source)
dify-forge-*.yml
# Dashboard dev render screenshots (generated by `forge dashboard` during local dev)
dashboard-render.png
